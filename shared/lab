#!/usr/bin/env bash

# Lab CLI - Centralized management for lab projects

LAB_DIR="/home/mlovera/lab"
SEARCH_DIRS=("core" "external" "services")

# ANSI Color Codes
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
GRAY='\033[0;90m'
NC='\033[0m' # No Color

# Helper: Find all valid projects
get_projects() {
  local projects=()
  for dir in "${SEARCH_DIRS[@]}"; do
    if [ -d "$LAB_DIR/$dir" ]; then
      # Find directories containing docker-compose.yml
      while IFS= read -r compose_file; do
        if [ -n "$compose_file" ]; then
          # Extract just the project name (the parent directory of docker-compose.yml)
          local proj_path=$(dirname "$compose_file")
          local proj_name=$(basename "$proj_path")
          projects+=("$proj_name:$proj_path")
        fi
      done < <(find -L "$LAB_DIR/$dir" -mindepth 1 -maxdepth 2 -name "docker-compose.yml" 2>/dev/null)
    fi
  done
  echo "${projects[@]}"
}



# Helper: Find path for a specific project
get_project_path() {
  local target_proj="$1"
  local projects=($(get_projects))
  for item in "${projects[@]}"; do
    local name="${item%%:*}"
    local path="${item#*:}"
    if [ "$name" == "$target_proj" ]; then
      echo "$path"
      return 0
    fi
  done
  return 1
}

# Command: help
cmd_help() {
  echo -e "${CYAN}Lab CLI - Management Guide${NC}"
  echo -e "Usage: ${GREEN}lab <command> [options] [project]${NC}"
  echo ""
  echo -e "${YELLOW}Commands:${NC}"
  echo -e "  ${GREEN}list${NC}            List all projects found in core/, external/, and services/."
  echo -e "  ${GREEN}ps [-a]${NC}         Show projects status. Use -a to show stopped projects too."
  echo -e "  ${GREEN}up <name>${NC}       Start a project (docker compose up -d)."
  echo -e "  ${GREEN}down <name>${NC}     Stop a project (docker compose down)."
  echo -e "  ${GREEN}logs <name>${NC}     View real-time logs for a project."
  echo -e "  ${GREEN}help, -h${NC}        Show this guide."
  echo ""
  echo -e "${YELLOW}Examples:${NC}"
  echo "  lab up n8n         # Starts the n8n service"
  echo "  lab up postgres    # Starts the shared database"
  echo "  lab ps -a          # Checks status of all projects"
  echo "  lab logs traefik   # Tails the Traefik proxy logs"
}

# Command: list
cmd_list() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${CYAN}Command: list${NC}"
    echo "Description: Scans core/, external/, and services/ directories for docker-compose.yml files."
    echo "Usage: lab list"
    return
  fi
  echo -e "${CYAN}Available Lab Projects:${NC}"
  local projects=($(get_projects))
  if [ ${#projects[@]} -eq 0 ]; then
    echo "No projects found."
    return
  fi
  for item in "${projects[@]}"; do
    local name="${item%%:*}"
    local path="${item#*:}"
    # Make path relative to LAB_DIR for display
    local rel_path="${path#$LAB_DIR/}"
    printf "  ${GREEN}%-15s${NC} (%s)\n" "$name" "$rel_path"
  done
}

# Command: ps
cmd_ps() {
  local show_all=false
  if [[ "$1" == "-a" ]]; then
    show_all=true
  elif [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${CYAN}Command: ps${NC}"
    echo "Description: Checks each project to see if it has running containers and shows network access."
    echo "Options: -a  Show all projects (including stopped ones)"
    echo "Usage: lab ps [-a]"
    return
  fi

  if [ "$show_all" = true ]; then
    echo -e "${CYAN}All Lab Projects Status:${NC}"
  else
    echo -e "${CYAN}Running Lab Projects:${NC}"
  fi

  local projects=($(get_projects))
  local found_any=false

  for item in "${projects[@]}"; do
    local name="${item%%:*}"
    local path="${item#*:}"
    
    # Check if there are any running containers for this compose file
    local container_ids=$(cd -P "$path" && docker compose -p "$name" ps -q 2>/dev/null)
    
    if [ -n "$container_ids" ]; then
      printf "  ${GREEN}● %-15s${NC} (Running)\n" "$name"
      found_any=true
      
      # Inspect networking for each running container in the project
      local host_ip=$(hostname -I | awk '{print $1}')
      for id in $container_ids; do
        # 1. Get Traefik labels for domains
        local labels=$(docker inspect --format '{{ range $k, $v := .Config.Labels }}{{ $v }}{{ "\n" }}{{ end }}' "$id" | grep "Host(")
        
        # 2. Get Published Ports for localhost access
        local ports=$(docker inspect --format '{{ range $p, $conf := .NetworkSettings.Ports }}{{ if $conf }}{{ (index $conf 0).HostPort }}{{ "\n" }}{{ end }}{{ end }}' "$id" | sort -u)

        # Display Localhost and IP URLs
        for port in $ports; do
          echo -e "      ${GRAY}→ Localhost:   ${NC}http://localhost:$port"
          if [ -n "$host_ip" ]; then
            echo -e "      ${GRAY}→ Local IP:    ${NC}http://$host_ip:$port"
          fi
        done

        # Display Domain URLs from labels
        if [ -n "$labels" ]; then
          # Extract hostnames from Traefik rules like Host(`n8n.rpi.local`)
          local hosts=$(echo "$labels" | grep -oP "Host\(\`\K[^'\`]+" | tr ',' '\n')
          for host in $hosts; do
            if [[ "$host" == *".rpi.local"* ]]; then
              echo -e "      ${GRAY}→ Local Net:   ${NC}http://$host"
            elif [[ "$host" == *".mlovera.dev"* ]]; then
              echo -e "      ${GRAY}→ Production:  ${NC}https://$host"
            fi
          done
        fi
      done
    elif [ "$show_all" = true ]; then
      printf "  ${GRAY}○ %-15s${NC} (Stopped)\n" "$name"
      found_any=true
    fi
  done

  if [ "$found_any" = false ]; then
    if [ "$show_all" = true ]; then
      echo "  No projects found."
    else
      echo "  No projects are currently running."
    fi
  fi
}

# Command: up
cmd_up() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${CYAN}Command: up${NC}"
    echo "Description: Starts the specified project in detached mode."
    echo "Usage: lab up <project_name>"
    return
  fi
  local proj="$1"
  if [ -z "$proj" ]; then
    echo -e "${RED}Error: Project name required.${NC} Usage: lab up <project>"
    return 1
  fi

  local path=$(get_project_path "$proj")
  if [ -z "$path" ]; then
    echo -e "${RED}Error: Project '$proj' not found.${NC}"
    return 1
  fi

  # Resolve symlinks to avoid project name conflicts
  path=$(realpath "$path")

  echo -e "${YELLOW}Starting '$proj'...${NC}"
  cd -P "$path"
  
  # Load global environment if exists
  local env_arg=""
  if [ -f "$LAB_DIR/.env" ]; then
    env_arg="--env-file $LAB_DIR/.env"
  fi

  if [ -f "./docker-setup.sh" ]; then
    echo -e "${GRAY}Detected docker-setup.sh, running it...${NC}"
    # Note: docker-setup.sh should probably also handle .env, but for now we focus on standard compose
    bash ./docker-setup.sh
  else
    docker compose -p "$proj" $env_arg up -d
  fi
}

# Command: down
cmd_down() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${CYAN}Command: down${NC}"
    echo "Description: Stops and removes containers for the specified project."
    echo "Usage: lab down <project_name>"
    return
  fi
  local proj="$1"
  if [ -z "$proj" ]; then
    echo -e "${RED}Error: Project name required.${NC} Usage: lab down <project>"
    return 1
  fi

  local path=$(get_project_path "$proj")
  if [ -z "$path" ]; then
    echo -e "${RED}Error: Project '$proj' not found.${NC}"
    return 1
  fi

  # Resolve symlinks to avoid project name conflicts
  path=$(realpath "$path")

  echo -e "${YELLOW}Stopping '$proj'...${NC}"
  cd -P "$path"
  
  # Load global environment if exists
  local env_arg=""
  if [ -f "$LAB_DIR/.env" ]; then
    env_arg="--env-file $LAB_DIR/.env"
  fi
  
  docker compose -p "$proj" $env_arg down
}

# Command: logs
cmd_logs() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${CYAN}Command: logs${NC}"
    echo "Description: Displays and follows the log output for the specified project."
    echo "Usage: lab logs <project_name>"
    return
  fi
  local proj="$1"
  if [ -z "$proj" ]; then
    echo -e "${RED}Error: Project name required.${NC} Usage: lab logs <project>"
    return 1
  fi

  local path=$(get_project_path "$proj")
  if [ -z "$path" ]; then
    echo -e "${RED}Error: Project '$proj' not found.${NC}"
    return 1
  fi

  # Resolve symlinks to avoid project name conflicts
  path=$(realpath "$path")

  cd -P "$path"
  
  # Load global environment if exists
  local env_arg=""
  if [ -f "$LAB_DIR/.env" ]; then
    env_arg="--env-file $LAB_DIR/.env"
  fi
  
  docker compose -p "$proj" $env_arg logs -f
}

# Main routing
case "$1" in
  list)
    cmd_list "$2"
    ;;
  ps)
    cmd_ps "$2"
    ;;
  up)
    cmd_up "$2"
    ;;
  down)
    cmd_down "$2"
    ;;
  logs)
    cmd_logs "$2"
    ;;
  help|-h|--help)
    cmd_help
    ;;
  *)
    cmd_help
    ;;
esac
