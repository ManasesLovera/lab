#!/usr/bin/env bash

# Secrets Manager CLI - Lab Credential & DB Management

LAB_DIR="/home/mlovera/lab"
SEARCH_DIRS=("core" "external" "services")
DB_PATH="$LAB_DIR/shared/data/secrets.db"

# ANSI Color Codes
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Helper: Initialize SQLite DB using Python
init_db() {
    mkdir -p "$(dirname "$DB_PATH")"
    python3 -c "
import sqlite3
import os
db_path = os.environ.get('DB_PATH', '$DB_PATH')
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute(\"SELECT name FROM sqlite_master WHERE type='table' AND name='user_creation_log'\")
if not cur.fetchone():
    cur.execute('CREATE TABLE user_creation_log (id INTEGER PRIMARY KEY, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP, type TEXT, dbname TEXT, username TEXT, permissions TEXT)')
cur.execute(\"SELECT name FROM sqlite_master WHERE type='table' AND name='secrets'\")
if not cur.fetchone():
    cur.execute('CREATE TABLE secrets (key TEXT PRIMARY KEY, value TEXT)')
conn.commit()
conn.close()
"
}

# Helper: Log user creation
log_user_creation() {
    local type="$1"
    local dbname="$2"
    local username="$3"
    local perms="$4"
    python3 -c "
import sqlite3
import os
from datetime import datetime
db_path = os.environ.get('DB_PATH', '$DB_PATH')
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute('INSERT INTO user_creation_log (type, dbname, username, permissions) VALUES (?, ?, ?, ?)', ('$type', '$dbname', '$username', '$perms'))
conn.commit()
conn.close()
"
}

# Helper: Store a secret
cmd_store() {
    init_db
    local key="$1"
    local value="$2"
    if [[ -z "$key" || -z "$value" ]]; then
        echo -e "${RED}Error: Missing key or value.${NC}"
        echo "Usage: secrets store <key> <value>"
        return 1
    fi
    python3 -c "
import sqlite3
import os
db_path = os.environ.get('DB_PATH', '$DB_PATH')
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute('INSERT OR REPLACE INTO secrets (key, value) VALUES (?, ?)', ('$key', '$value'))
conn.commit()
conn.close()
"
    echo -e "${GREEN}Stored secret: $key${NC}"
}

# Helper: Get a secret
cmd_get() {
    init_db
    local key="$1"
    if [[ -z "$key" ]]; then
        echo -e "${RED}Error: Missing key.${NC}"
        echo "Usage: secrets get <key>"
        return 1
    fi
    local value=$(python3 -c "
import sqlite3
import os
db_path = os.environ.get('DB_PATH', '$DB_PATH')
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute('SELECT value FROM secrets WHERE key = ?', ('$key',))
row = cur.fetchone()
print(row[0] if row else '')
conn.close()
")
    if [[ -n "$value" ]]; then
        echo "$value"
    else
        echo -e "${RED}Secret not found: $key${NC}"
        return 1
    fi
}

# Helper: Load env file if exists
load_env() {
    local env_path="$1"
    if [ -f "$env_path" ]; then
        # Parse .env file manually to handle quotes and comments correctly
        while IFS='=' read -r key value || [ -n "$key" ]; do
            # Skip comments and empty lines
            [[ "$key" =~ ^#.*$ || -z "$key" ]] && continue
            
            # Trim whitespace
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
            
            # Remove surrounding quotes
            value="${value%\"}"
            value="${value#\"}"
            value="${value%\'}"
            value="${value#\'}"
            
            export "$key=$value"
        done < "$env_path"
    fi
}

cmd_help() {
    echo -e "${CYAN}Secrets Manager - Lab Credentials & DB Access${NC}"
    echo -e "Usage: ${GREEN}secrets <command> [options]${NC}"
    echo ""
    echo -e "${YELLOW}Commands:${NC}"
    echo -e "  ${GREEN}list${NC}                           Show all credentials found in .env files."
    echo -e "  ${GREEN}history${NC}                        Show history of created DB users."
    echo -e "  ${GREEN}store <key> <value>${NC}            Store a secret locally."
    echo -e "  ${GREEN}get <key>${NC}                     Retrieve a stored secret."
    echo -e "  ${GREEN}db create-user <type>${NC}          Create a new DB user."
    echo ""
    echo -e "${YELLOW}Database Support:${NC}"
    echo -e "  ${CYAN}postgres${NC}  <dbname> <user> <pass>"
    echo -e "  ${CYAN}mongo${NC}     <dbname> <user> <pass>"
    echo -e "  ${CYAN}mssql${NC}     <dbname> <user> <pass>"
}

cmd_list() {
    echo -e "${CYAN}Active Lab Credentials:${NC}"
    for dir in "${SEARCH_DIRS[@]}"; do
        find "$LAB_DIR/$dir" -maxdepth 2 -name ".env" | while read -r env_file; do
            local proj_name=$(basename $(dirname "$env_file"))
            echo -e "${YELLOW}--- $proj_name ---${NC}"
            cat "$env_file" | grep -v '^#' | sed 's/^/  /'
        done
    done
}

cmd_history() {
    init_db
    echo -e "${CYAN}User Creation History:${NC}"
    python3 -c "
import sqlite3
import os
db_path = os.environ.get('DB_PATH', '$DB_PATH')
conn = sqlite3.connect(db_path)
cur = conn.cursor()
cur.execute('SELECT timestamp, type, dbname, username, permissions FROM user_creation_log ORDER BY timestamp DESC')
rows = cur.fetchall()
if rows:
    print(f'{'Timestamp':<25} {'Type':<10} {'DB Name':<15} {'Username':<15} {'Permissions':<30}')
    print('-' * 95)
    for row in rows:
        print(f'{row[0]:<25} {row[1]:<10} {row[2]:<15} {row[3]:<15} {row[4]:<30}')
else:
    print('No user creation history found.')
conn.close()
"
}

cmd_db_create_user() {
    init_db
    local type="$1"
    local dbname="$2"
    local username="$3"
    local password="$4"

    if [[ -z "$type" || -z "$dbname" || -z "$username" || -z "$password" ]]; then
        echo -e "${RED}Error: Missing arguments.${NC}"
        echo "Usage: secrets db create-user <postgres|mongo|mssql> <dbname> <username> <password>"
        return 1
    fi

    case "$type" in
        postgres)
            load_env "$LAB_DIR/core/postgres/.env"
            # Ensure password is provided for authentication
            export PGPASSWORD="$POSTGRES_PASSWORD"
            echo -e "${YELLOW}Creating Postgres user '$username' for DB '$dbname'...${NC}"
            docker exec -i postgres psql -U "${POSTGRES_USER:-admin}" -d postgres <<EOF
CREATE USER $username WITH PASSWORD '$password';
CREATE DATABASE $dbname;
GRANT ALL PRIVILEGES ON DATABASE $dbname TO $username;
\c $dbname
GRANT ALL ON SCHEMA public TO $username;
EOF
            unset PGPASSWORD
            log_user_creation "postgres" "$dbname" "$username" "ALL PRIVILEGES, public schema"
            ;;
        mongo)
            load_env "$LAB_DIR/core/mongo/.env"
            echo -e "${YELLOW}Creating MongoDB user '$username' for DB '$dbname'...${NC}"
            docker exec -i mongo mongosh -u "${MONGO_INITDB_ROOT_USERNAME:-admin}" -p "${MONGO_INITDB_ROOT_PASSWORD}" --authenticationDatabase admin --eval "
                db = db.getSiblingDB('$dbname');
                db.createUser({
                    user: '$username',
                    pwd: '$password',
                    roles: [{ role: 'readWrite', db: '$dbname' }]
                });
            "
            log_user_creation "mongo" "$dbname" "$username" "readWrite"
            ;;
        mssql)
            load_env "$LAB_DIR/core/mssql/.env"
            echo -e "${YELLOW}Creating MSSQL user '$username' for DB '$dbname'...${NC}"
            docker exec -i mssql /opt/mssql-tools/bin/sqlcmd -S localhost -U sa -P "${MSSQL_SA_PASSWORD}" -Q "
                CREATE DATABASE [$dbname];
                GO
                CREATE LOGIN [$username] WITH PASSWORD = '$password';
                GO
                USE [$dbname];
                GO
                CREATE USER [$username] FOR LOGIN [$username];
                GO
                EXEC sp_addrolemember 'db_owner', '$username';
                GO
            "
            log_user_creation "mssql" "$dbname" "$username" "db_owner"
            ;;
        *)
            echo -e "${RED}Unsupported database type: $type${NC}"
            return 1
            ;;
    esac
}

case "$1" in
    list) cmd_list ;;
    history) cmd_history ;;
    store) shift; cmd_store "$@" ;;
    get) shift; cmd_get "$@" ;;
    db) 
        if [[ "$2" == "create-user" ]]; then
            shift 2
            cmd_db_create_user "$@"
        else
            cmd_help
        fi
        ;;
    help|-h|--help|*) cmd_help ;;
esac